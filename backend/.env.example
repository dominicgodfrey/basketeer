# Copy to .env (gitignored) and fill in only the keys you've decided to use.
# See ../SETUP.md for the meaning of each key and when it becomes required.

# ---- App ----
ENVIRONMENT=dev
LOG_LEVEL=INFO

# ---- LLM providers (pick one or more) ----
# Anthropic — Claude family
# ANTHROPIC_API_KEY=

# Google — Gemini family
# GOOGLE_API_KEY=

# OpenAI-compatible endpoint — DeepSeek, Together, Groq, Fireworks, etc.
# Set both BASE_URL and API_KEY together.
# OPENAI_COMPAT_BASE_URL=https://api.deepseek.com
# OPENAI_COMPAT_API_KEY=

# ---- Per-task model overrides (optional) ----
# Override the default routing table without editing code. Format:
# MODEL_<TASK>=<provider>:<model_id>
# Providers: anthropic | google | openai-compatible
# Tasks: intent_classifier | agent_planning | text_to_sql | code_generation | narrative_write
#
# Example: route everything to DeepSeek
# MODEL_INTENT_CLASSIFIER=openai-compatible:deepseek-chat
# MODEL_AGENT_PLANNING=openai-compatible:deepseek-chat
# MODEL_TEXT_TO_SQL=openai-compatible:deepseek-chat
# MODEL_CODE_GENERATION=openai-compatible:deepseek-chat
# MODEL_NARRATIVE_WRITE=openai-compatible:deepseek-chat

# ---- Vector store ----
# PINECONE_API_KEY=
# PINECONE_INDEX_NAME=basketeer-stat-profiles

# ---- Compute sandbox ----
# E2B_API_KEY=

# ---- Cache ----
# REDIS_URL=redis://default:password@host:port

# ---- Postgres (collaborator's track) ----
# DATABASE_URL=postgres://user:pw@host/db
# DATABASE_URL_READONLY=postgres://readonly_user:pw@host/db
